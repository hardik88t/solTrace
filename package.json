{
  "name": "solTrace",
  "version": "1.0.0",
  "description": "Comprehensive tool for analyzing Solana blockchain transactions related to token launches",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "analyze": "ts-node src/cli/analyze.ts",
    "diagram": "ts-node src/cli/diagram.ts",
    "test": "ts-node src/cli/test.ts",
    "sample": "ts-node src/examples/sample-analysis.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "solana",
    "blockchain",
    "token-launch",
    "analysis",
    "sequence-diagram",
    "cryptocurrency"
  ],
  "author": "Solana Token Launch Analyzer",
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "^1.87.6",
    "@solana/spl-token": "^0.3.9",
    "mermaid": "^10.6.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jest": "^29.5.8",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
